---
export interface Props {
  sourceHref: string;
  ownerHref?: string;
  ownerName?: string;
  year?: number;
}

const {
  sourceHref,
  ownerHref = 'https://github.com/brainage04',
  ownerName = 'brainage04',
  year = new Date().getFullYear(),
} = Astro.props;
---

<footer class="site-footer">
  <div class="footer-inner">
    <span>© {year} <a href={ownerHref} target="_blank" rel="noreferrer">{ownerName}</a></span>
    <span>Made with <a href="https://astro.build/" target="_blank" rel="noreferrer">Astro</a> + <a href="https://webtui.ironclad.sh/" target="_blank" rel="noreferrer">WebTUI</a></span>
    <a href={sourceHref} target="_blank" rel="noreferrer">Source code</a>
  </div>
</footer>

<style>
  .site-footer {
    border-block-start: 1px solid var(--foreground2);
    color: var(--foreground2);
  }

  .footer-inner {
    width: min(100% - 1rem, var(--site-footer-width, 72rem));
    margin-inline: auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    padding-block: 1rem;
  }

  a {
    color: var(--foreground1);
    text-underline-offset: 0.18em;
  }

  a:hover {
    color: var(--accent-cyan);
  }
  @media (max-width: 520px) {
    .footer-inner {
      display: grid;
      justify-items: center;
      justify-content: center;
      text-align: center;
    }
  }

</style>
