---
export interface Props {
  title?: string;
  class?: string;
  id?: string;
}

const { title, class: className, id } = Astro.props;
---

<section id={id} class:list={['terminal-panel', className]} box-="square">
  {title && (
    <div class="panel-header">
      <strong>{title}</strong>
    </div>
  )}
  <slot />
</section>
