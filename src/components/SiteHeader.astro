---
export interface NavItem {
  name: string;
  href: string;
  external?: boolean;
  match?: string;
  activeMode?: 'exact' | 'prefix';
}

export interface Props {
  items: readonly NavItem[];
  pathname: string;
  brandLabel?: string;
  brandHref?: string;
}

const { items, pathname, brandLabel, brandHref = '/' }: Props = Astro.props;

function stripTrailingSlash(value: string) {
  return value === '/' ? value : value.replace(/\/$/, '');
}

function isActive(item: NavItem) {
  if (item.external) return false;
  const normalizedPathname = stripTrailingSlash(pathname);
  const normalizedTarget = stripTrailingSlash(item.match ?? item.href);
  if (item.activeMode === 'prefix') {
    if (normalizedTarget === '/') return normalizedPathname === '/';
    return normalizedPathname === normalizedTarget || normalizedPathname.startsWith(`${normalizedTarget}/`);
  }
  return normalizedPathname === normalizedTarget;
}
---

<header class="site-header">
  <nav aria-label="Primary navigation" data-has-brand={brandLabel ? 'true' : undefined}>
    {brandLabel && <a class="site-brand" href={brandHref}>{brandLabel}</a>}
    <div class="nav-links">
      {items.map((item) => {
        const active = isActive(item);
        return (
          <a href={item.href} aria-current={active ? 'page' : undefined} data-active={active ? 'true' : undefined}>
            {item.name}
          </a>
        );
      })}
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    inset-block-start: 0;
    z-index: 5;
    background: color-mix(in srgb, var(--background0) 90%, transparent);
    backdrop-filter: blur(12px);
    border-block-end: 1px solid color-mix(in srgb, var(--foreground2) 45%, transparent);
  }

  nav {
    width: min(100% - 1.5rem, var(--site-nav-width, 70rem));
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    padding-block: clamp(0.65rem, 1.4vw, 0.85rem);
  }

  nav[data-has-brand='true'] {
    justify-content: space-between;
  }

  .site-brand {
    color: var(--accent-cyan);
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }

  .site-brand::before {
    content: '> ';
    color: var(--foreground2);
  }

  .site-brand:hover {
    color: var(--foreground0);
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem clamp(1.55rem, 4vw, 2.7rem);
    align-items: center;
  }

  .nav-links a {
    color: var(--foreground1);
    text-decoration: none;
    border-block-end: 2px solid transparent;
    padding-block: 0.2rem;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .nav-links a:hover,
  .nav-links a[data-active='true'] {
    color: var(--foreground0);
    border-block-end-color: var(--accent-cyan);
  }

  @media (max-width: 700px) {
    .site-brand {
      display: none;
    }

    nav[data-has-brand='true'] {
      justify-content: center;
    }
  }

  @media (max-width: 520px) {
    nav {
      align-items: flex-start;
      padding-block: 0.25rem;
    }

    .nav-links {
      width: 100%;
      justify-content: space-between;
      gap: 0.4rem clamp(0.65rem, 4vw, 1rem);
    }

    .nav-links a {
      display: inline-flex;
      min-height: 2.75rem;
      align-items: center;
    }
  }
</style>
