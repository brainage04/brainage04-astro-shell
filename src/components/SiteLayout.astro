---
import SiteFooter from './SiteFooter.astro';
import SiteHeader, { type NavItem } from './SiteHeader.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  siteName: string;
  navItems: readonly NavItem[];
  sourceHref: string;
  description?: string;
  homeTitle?: string;
  faviconHref?: string;
  faviconType?: string;
}

const {
  title,
  siteName,
  navItems,
  sourceHref,
  description,
  homeTitle = siteName,
  faviconHref,
  faviconType,
} = Astro.props;
const pageTitle = title === 'Home' ? homeTitle : `${title} | ${siteName}`;
---

<!doctype html>
<html lang="en" data-webtui-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {description && <meta name="description" content={description} />}
    <title>{pageTitle}</title>
    {faviconHref && <link rel="icon" type={faviconType} href={faviconHref} />}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <SiteHeader items={navItems} pathname={Astro.url.pathname} />
    <main id="main">
      <slot />
    </main>
    <SiteFooter sourceHref={sourceHref} />
  </body>
</html>
